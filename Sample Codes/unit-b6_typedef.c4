// Test Case B6: This testcase demonstrates the capabilies of C4Chinese in using the typedef feature.

// Typedefs can be used as seen here...
yisi hao[3] intArr;

hao main(){

  // All defined typedefs act as working aliases to their actual datatype.
  // As such, the following line is equivalent to 'hao[3] myArr'
  intArr myArr;
  myArr[0] = 8;
  myArr[1] = 88;
  myArr[2] = 888;

  geini(myArr[0]);
  geini(myArr[1]);
  geini(myArr[2]);

  huijia 0;
}